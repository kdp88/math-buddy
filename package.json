{
  "name": "math-buddy",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deploy:lambda": "powershell -Command \"Compress-Archive -Force -Path lambda/mathBuddy.mjs -DestinationPath lambda/mathBuddy.zip\" && aws lambda update-function-code --function-name mathbuddy --zip-file fileb://lambda/mathBuddy.zip && powershell -Command \"Remove-Item lambda/mathBuddy.zip\""
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "moduleNameMapper": {
      "expo/src/winter/runtime": "<rootDir>/__mocks__/empty.js",
      "expo/src/winter/ImportMetaRegistry": "<rootDir>/__mocks__/ImportMetaRegistry.js"
    },
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "expo": "~55.0.5",
    "expo-gl": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-web": "^0.21.0",
    "three": "^0.183.2"
  },
  "private": true,
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-preset-expo": "^55.0.10",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.9"
  }
}
